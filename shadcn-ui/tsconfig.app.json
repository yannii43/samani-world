{
  "compilerOptions": {
    /* Target & libs */
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,

    /* Module / bundler (Vite) */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* React */
    "jsx": "react-jsx",

    /* Interop / types */
    "skipLibCheck": true,
    "types": ["vite/client"],

    /* Alias @ -> src */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* Linting / strictness (comme tu veux : permissif) */
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false
  },
  "include": ["src"]
}
